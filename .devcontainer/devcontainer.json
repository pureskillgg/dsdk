{
  "name": "Python",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "VARIANT": "3.9"
    }
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/bin"
  },
  "extensions": [
    "ms-vsliveshare.vsliveshare",
    "ms-python.python",
    "EditorConfig.EditorConfig"
  ],
  "features": {
    "git-lfs": "latest"
  },
  "postCreateCommand": "git lfs fetch && git lfs checkout && uv sync",
  "remoteUser": "vscode"
}
